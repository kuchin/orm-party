---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Sidebar from "../components/Sidebar.astro";

interface Props {
    currentCategory?: string;
}

const { currentCategory } = Astro.props;
const showSidebar = !!currentCategory;
const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta
            name="description"
            content="Side-by-side comparison of ORM syntax across SQL, Django, SQLAlchemy, SQLModel, Tortoise, Peewee, Prisma, Drizzle, Kysely, TypeORM, MikroORM, and Sequelize"
        />
        <meta property="og:title" content="ORM Party" />
        <meta
            property="og:description"
            content="Side-by-side comparison of ORM syntax across SQL, Django, SQLAlchemy, SQLModel, Tortoise, Peewee, Prisma, Drizzle, Kysely, TypeORM, MikroORM, and Sequelize"
        />
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://orm-party.fkey.dev" />
        <meta name="twitter:card" content="summary" />
        <meta name="twitter:title" content="ORM Party" />
        <meta
            name="twitter:description"
            content="Side-by-side comparison of ORM syntax across SQL, Django, SQLAlchemy, SQLModel, Tortoise, Peewee, Prisma, Drizzle, Kysely, TypeORM, MikroORM, and Sequelize"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>ORM Party</title>
        {gaId && (
            <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
            <script define:vars={{ gaId }}>
                window.dataLayer = window.dataLayer || [];
                function gtag(){dataLayer.push(arguments);}
                gtag('js', new Date());
                gtag('config', gaId);
            </script>
        )}
        <ViewTransitions />
    </head>
    <body class="bg-gray-950 text-gray-100 min-h-screen">
        <Header />
        <div class="flex">
            {showSidebar && <Sidebar currentSlug={currentCategory} />}
            <main class="flex-1 min-w-0">
                <slot />
            </main>
        </div>
    </body>
</html>
