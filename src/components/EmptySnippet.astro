---
import type { OrmDef } from "../data/orms";

interface Props {
  orm: OrmDef;
}

const { orm } = Astro.props;
---

<div
  class="max-w-2xl rounded-lg border border-gray-800 bg-gray-900/30 overflow-hidden"
  data-orm={orm.id}
>
  <div class="flex items-center px-4 py-2 border-b border-gray-800">
    <span class="font-medium text-sm text-gray-500">{orm.name}</span>
  </div>
  <div class="p-8 text-center text-gray-600 text-sm italic">
    Not applicable for this ORM
  </div>
</div>
