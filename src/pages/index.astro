---
import { getCollection } from "astro:content";
import { categories } from "../data/categories";
import Layout from "../layouts/Layout.astro";
import CategoryPage from "../components/CategoryPage.astro";

const category = categories[0];
const prevCategory = undefined;
const nextCategory = categories[1];
const allSnippets = await getCollection("snippets");
const categorySnippets = allSnippets.filter(
  (s) => s.data.categorySlug === category.contentSlug,
);
---

<Layout currentCategory={category.slug}>
  <CategoryPage
    category={category}
    snippets={categorySnippets}
    prevCategory={prevCategory}
    nextCategory={nextCategory}
  />
</Layout>
