---
import Layout from "../layouts/Layout.astro";
import { orms } from "../data/orms";
import { categories } from "../data/categories";

const totalScenarios = categories.reduce(
    (sum, c) => sum + c.scenarios.length,
    0,
);
const ormList = orms.filter((o) => o.id !== "sql");
---

<Layout>
    <div class="max-w-2xl mx-auto px-6 py-12">
        <h1 class="text-2xl font-bold mb-6">About</h1>

        <div class="space-y-4 text-gray-300 text-sm leading-relaxed">
            <p>
                ORM Party is a side-by-side comparison of ORM syntax across
                different languages and frameworks. It helps developers quickly
                see how the same database operation looks in different ORMs.
            </p>

            <p>Currently covering:</p>

            <ul class="list-none space-y-2 pl-4">
                <li class="flex items-center gap-2">
                    <img src="/orm/sql.svg" alt="" class="w-4 h-4" />
                    <span class="text-white">Raw SQL</span>
                    <!-- <span class="text-gray-500">— PostgreSQL</span> -->
                </li>
                {
                    ormList.map((orm) => (
                        <li class="flex items-center gap-2">
                            <img
                                src={`/orm/${orm.id}.svg`}
                                alt=""
                                class="w-4 h-4"
                            />
                            <a
                                href={orm.website}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="text-white hover:text-blue-400"
                            >
                                {orm.name}
                            </a>
                            <!-- <span class="text-gray-500">
                                —{" "}
                                {orm.language === "python"
                                    ? "Python"
                                    : "TypeScript"}
                            </span> -->
                        </li>
                    ))
                }
            </ul>

            <p>
                All examples use PostgreSQL as the database. Snippets show
                idiomatic usage for each ORM — when a feature isn't natively
                supported, we show the closest workaround or raw SQL fallback.
            </p>

            <p class="pt-4 mt-8 border-t border-gray-800">
                Heavily inspired by{" "}
                <a
                    href="https://component-party.dev"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-400 hover:underline">component-party.dev</a
                >
            </p>

            <p>
                Built by Dima Kuchin at{" "}
                <a
                    href="https://mirable.io"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-blue-400 hover:underline">Mirable</a
                >
            </p>
        </div>
    </div>
</Layout>
